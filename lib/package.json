{
  "name": "bulma-css-vars",
  "version": "0.9.0",
  "description": "Bulma with CSS variables",
  "keywords": [
    "bulma",
    "bulma.io",
    "CSS Variables"
  ],
  "main": "./dist/cjs/index.js",
  "browser": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./*": {
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js"
    }
  },
  "files": [
    "/dist",
    "/bin",
    "/*.sass"
  ],
  "bin": {
    "bulma-css-vars": "bin/bulma-css-vars.cjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig-esm.json && webpack",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run build && cp ../README.md .",
    "test": "jest"
  },
  "author": "Thomas Wirth <thomas@wtho.de>",
  "repository": {
    "type": "git",
    "url": "https://github.com/to-bee/bulma-css-vars"
  },
  "license": "MIT",
  "engines": {
    "node": ">= 18.0.0"
  },
  "dependencies": {
    "color": "^4.2.3",
    "css": "^3.0.0"
  },
  "peerDependencies": {
    "bulma": "^0.9.3"
  },
  "devDependencies": {
    "@types/color": "^4.2.0",
    "@types/css": "^0.0.38",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "sass": "^1.86.0",
    "ts-jest": "^29.3.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.0"
  }
}
